#!/usr/bin/make -f

# See debhelper(7) (uncomment to enable).
# Output every command that modifies files on the build system.
#export DH_VERBOSE = 1


# See FEATURE AREAS in dpkg-buildflags(1).
#export DEB_BUILD_MAINT_OPTIONS = hardening=+all

# See ENVIRONMENT in dpkg-buildflags(1).
# Package maintainers to append CFLAGS.
#export DEB_CFLAGS_MAINT_APPEND  = -Wall -pedantic
# Package maintainers to append LDFLAGS.
#export DEB_LDFLAGS_MAINT_APPEND = -Wl,--as-needed

DEB_VERSION = $(shell dpkg-parsechangelog -SVersion)
DEB_VERSION_MAJOR = $(shell dpkg-parsechangelog -SVersion | cut -d. -f 1)

%:
	dh $@

override_dh_auto_install:
	dh_auto_install
	mkdir -p debian/tmp/lib/${DEB_HOST_MULTIARCH}
	mv debian/tmp/lib/libmdr.so \
		debian/tmp/lib/${DEB_HOST_MULTIARCH}/libmdr.so.${DEB_VERSION}
	ln -fs debian/tmp/lib/${DEB_HOST_MULTIARCH}/libmdr.so.${DEB_VERSION} \
		debian/tmp/lib/${DEB_HOST_MULTIARCH}/libmdr.so.${DEB_VERSION_MAJOR}
	mv debian/tmp/lib/libflatconf.so \
		debian/tmp/lib/${DEB_HOST_MULTIARCH}/libflatconf.so.${DEB_VERSION}
	ln -fs debian/tmp/lib/${DEB_HOST_MULTIARCH}/libflatconf.so.${DEB_VERSION} \
		debian/tmp/lib/${DEB_HOST_MULTIARCH}/libflatconf.so.${DEB_VERSION_MAJOR}


# dh_make generated override targets.
# This is an example for Cmake (see <https://bugs.debian.org/641051>).
#override_dh_auto_configure:
#	dh_auto_configure -- \
#	-DCMAKE_LIBRARY_PATH=$(DEB_HOST_MULTIARCH)

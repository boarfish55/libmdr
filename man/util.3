.Sh SYNOPSIS
.In mdr/util.h
.Ft int
.Fn daemonize "const char *program" "const char *pid_path" "int nochdir" "int noclose" "struct xerr *e"
.Ft int
.Fn drop_privileges "const char *user" "const char *group" "struct xerr *e"
.Ft ssize_t
.Fn readall "int fd" "void *buf" "size_t count"
.Ft ssize_t
.Fn writeall "int fd" "const void *buf" "size_t count"
.Fn CLOSE_X "fd"

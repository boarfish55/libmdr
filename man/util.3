.Fn close_x "int fd" "const char *fd_name" "const char *fn" "int line"
.Ft int
.Fo spawn
.Fa "char *const argv[]"
.Fa "pid_t *pid"
.Fa "int *in"
.Fa "int *out"
.Fa "const char *user"
.Fa "const char *group"
.Fa "struct xerr *e"
.Fc
.Ft int
.Fn spawnproc_init "struct spawnproc *sp" "int nochdir" "const char *execpromises" "char **perms"
.Ft int
.Fo spawnproc_exec
.Fa "struct spawnproc *sp"
.Fa "char *const argv[]"
.Fa "pid_t *cpid"
.Fa "int *in"
.Fa "int *out"
